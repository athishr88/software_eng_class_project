[Unit]
Description=gunicorn daemon
Requires=gunicorn.socket
After=network.target
[Service]
User=ubuntu
Group=www-data
WorkingDirectory=/home/ubuntu/software_eng_class_project
ExecStart=/home/ubuntu/env/bin/gunicorn --access-logfile - --workers 3 --bind unix:/home/ubuntu/software_eng_class_project/passiton/passiton.sock passiton.wsgi:application

       
[Install]
WantedBy=multi-user.target